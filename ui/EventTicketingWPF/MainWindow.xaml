<Window x:Class="EventTicketingWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Event Ticketing System" Height="750" Width="1000"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <!-- Colorful styles -->
        <LinearGradientBrush x:Key="HeaderBrush" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#FF6B6B" Offset="0"/>
            <GradientStop Color="#FF8E53" Offset="1"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="ButtonBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#FF4A90E2" Offset="0"/>
            <GradientStop Color="#FF357ABD" Offset="1"/>
        </LinearGradientBrush>

        <!-- Button style without BorderRadius -->
        <Style TargetType="Button">
            <Setter Property="Background" Value="{StaticResource ButtonBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Margin" Value="0,5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="5" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FF2C5F8A"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Margin" Value="0,5"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style TargetType="PasswordBox">
            <Setter Property="Margin" Value="0,5"/>
            <Setter Property="Padding" Value="5"/>
        </Style>
        <Style TargetType="DataGrid">
            <Setter Property="Margin" Value="0,5"/>
            <Setter Property="AlternatingRowBackground" Value="#F5F5F5"/>
            <Setter Property="RowBackground" Value="White"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
    </Window.Resources>

    <Grid Margin="15" Background="#FAFAFA">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Title Banner -->
        <Border Grid.Row="0" Background="{StaticResource HeaderBrush}" CornerRadius="8" Padding="10" Margin="0,0,0,15">
            <TextBlock Text="🎟️ Event Ticketing System" FontSize="28" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
        </Border>

        <!-- Main Content Panel -->
        <Grid Grid.Row="1">
            <!-- Login Panel -->
            <StackPanel Name="LoginPanel" Visibility="Visible" Width="350" HorizontalAlignment="Center">
                <Border Background="White" CornerRadius="10" Padding="20" Margin="0,20" BorderBrush="#DDD" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="🔐 Login" FontSize="24" FontWeight="Bold" Margin="0,0,0,15" HorizontalAlignment="Center"/>
                        <TextBlock Text="Email" Margin="0,5,0,0" Foreground="#555"/>
                        <TextBox Name="LoginEmail" Margin="0,5"/>
                        <TextBlock Text="Password" Margin="0,5,0,0" Foreground="#555"/>
                        <PasswordBox Name="LoginPassword" Margin="0,5"/>
                        <TextBlock Name="LoginError" Foreground="#E74C3C" Margin="0,5" TextWrapping="Wrap"/>
                        <Button Content="Login" Click="Login_Click" Background="#27AE60" Margin="0,15"/>
                        <Button Content="Create New Account" Click="GoToRegister_Click" Background="#3498DB"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Register Panel -->
            <StackPanel Name="RegisterPanel" Visibility="Collapsed" Width="400" HorizontalAlignment="Center">
                <Border Background="White" CornerRadius="10" Padding="20" Margin="0,20" BorderBrush="#DDD" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="📝 Register" FontSize="24" FontWeight="Bold" Margin="0,0,0,15" HorizontalAlignment="Center"/>
                        <TextBlock Text="First Name" Foreground="#555"/>
                        <TextBox Name="RegFirstName" Margin="0,5"/>
                        <TextBlock Text="Last Name" Foreground="#555"/>
                        <TextBox Name="RegLastName" Margin="0,5"/>
                        <TextBlock Text="Email" Foreground="#555"/>
                        <TextBox Name="RegEmail" Margin="0,5"/>
                        <TextBlock Text="Password" Foreground="#555"/>
                        <PasswordBox Name="RegPassword" Margin="0,5"/>
                        <TextBlock Text="Role" Foreground="#555"/>
                        <ComboBox Name="RegRole" Margin="0,5" SelectedIndex="0">
                            <ComboBoxItem Content="attendee"/>
                            <ComboBoxItem Content="organizer"/>
                        </ComboBox>
                        <TextBlock Name="RegError" Foreground="#E74C3C" Margin="0,5" TextWrapping="Wrap"/>
                        <Button Content="Register" Click="Register_Click" Background="#27AE60" Margin="0,15"/>
                        <Button Content="Back to Login" Click="BackToLogin_Click" Background="#7F8C8D"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Attendee Panel -->
            <Grid Name="AttendeePanel" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,5" HorizontalAlignment="Right">
                    <TextBlock Text="Welcome, " FontSize="14"/>
                    <TextBlock Name="AttendeeName" FontSize="14" FontWeight="Bold" Foreground="#27AE60"/>
                    <Button Content="Logout" Click="Logout_Click" Width="80" Margin="20,0,0,0" Background="#E74C3C"/>
                </StackPanel>
                <Border Grid.Row="1" Background="White" CornerRadius="8" Padding="10" Margin="0,10" BorderBrush="#DDD" BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                            <TextBlock Text="📅 Upcoming Events" FontSize="18" FontWeight="Bold"/>
                            <Button Content="Refresh" Click="BrowseEvents_Click" Width="80" Margin="20,0,0,0" Background="#3498DB"/>
                            <Button Content="📋 My Orders" Click="ViewOrders_Click" Width="100" Margin="20,0,0,0" Background="#9B59B6"/>
                            <Button Content="❌ Cancel Order" Click="CancelOrder_Click" Width="110" Margin="10,0,0,0" Background="#E67E22"/>
                        </StackPanel>
                        <DataGrid Name="EventsGrid" Grid.Row="1" AutoGenerateColumns="True" IsReadOnly="True" SelectionMode="Single" SelectionChanged="EventsGrid_SelectionChanged"/>
                    </Grid>
                </Border>
                <Border Grid.Row="2" Background="White" CornerRadius="8" Padding="10" Margin="0,10" BorderBrush="#DDD" BorderThickness="1" Name="TicketTypesPanel" Visibility="Collapsed">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="🎫 Ticket Types" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
                        <ListBox Grid.Row="1" Name="TicketTypesListBox" Height="120" Margin="0,5"/>
                        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,10">
                            <TextBlock Text="Quantity:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBox Name="QuantityBox" Width="60" Text="1" Margin="0,0,20,0"/>
                            <Button Name="PurchaseBtn" Content="Purchase Selected Tickets" Click="PurchaseSelectedTickets_Click" Background="#27AE60" Width="180"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>

            <!-- Organizer Panel -->
            <Grid Name="OrganizerPanel" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,5">
                    <TextBlock Text="Welcome, " FontSize="14"/>
                    <TextBlock Name="OrganizerName" FontSize="14" FontWeight="Bold" Foreground="#27AE60"/>
                    <Button Content="Logout" Click="Logout_Click" Width="80" Margin="20,0,0,0" Background="#E74C3C"/>
                </StackPanel>
                <WrapPanel Grid.Row="1" Margin="0,20" HorizontalAlignment="Center">
                    <Button Content="➕ Create Event" Click="CreateEvent_Click" Width="150" Margin="10" Background="#2ECC71"/>
                    <Button Content="📋 My Events" Click="MyEvents_Click" Width="150" Margin="10" Background="#3498DB"/>
                    <Button Content="📊 Sales Report" Click="SalesReport_Click" Width="150" Margin="10" Background="#F39C12"/>
                    <Button Content="✅ Check-in Attendee" Click="CheckIn_Click" Width="160" Margin="10" Background="#9B59B6"/>
                </WrapPanel>
                <DataGrid Name="OrganizerEventsGrid" Grid.Row="2" AutoGenerateColumns="True" IsReadOnly="True" Margin="0,10"/>
            </Grid>

            <!-- Admin Panel -->
            <Grid Name="AdminPanel" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,5">
                    <Button Content="Logout" Click="Logout_Click" Width="80" Background="#E74C3C"/>
                </StackPanel>
                <WrapPanel Grid.Row="1" Margin="0,20" HorizontalAlignment="Center">
                    <Button Content="👥 Manage Users" Click="ManageUsers_Click" Width="150" Margin="10"/>
                    <Button Content="📅 All Events" Click="AdminAllEvents_Click" Width="150" Margin="10"/>
                    <Button Content="💰 System Reports" Click="SystemReports_Click" Width="150" Margin="10"/>
                </WrapPanel>
                <DataGrid Name="AdminDataGrid" Grid.Row="2" AutoGenerateColumns="True" IsReadOnly="True" Margin="0,10"/>
            </Grid>
        </Grid>
    </Grid>
</Window>